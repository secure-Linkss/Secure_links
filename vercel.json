{
  "version": 2,
  "builds": [
    { 
      "src": "package.json", 
      "use": "@vercel/static-build", 
      "config": { "distDir": "dist" }
    },
    { 
      "src": "api/**/*.py", 
      "use": "@vercel/python",
      "config": { "runtime": "python3.9", "maxDuration": 10 }
    },
    { 
      "src": "api/**/*.js", 
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "SECRET_KEY": "@secret_key",
    "DATABASE_URL": "@database_url",
    "SHORTIO_API_KEY": "@shortio_api_key",
    "SHORTIO_DOMAIN": "@shortio_domain"
  }
}
